# JobForge AI - Environment Configuration Template
# Copy this to .env and fill in your values

# ==================
# Database Config (PostgreSQL)
# ==================
POSTGRES_PASSWORD=jobforge_password
DATABASE_URL=postgresql://postgres:jobforge_password@localhost:5432/jobforge_ai

# ==================
# Redis Config
# ==================
REDIS_PASSWORD=redis_password
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/2

# ==================
# FastAPI Config
# ==================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# ==================
# Azure Blob Storage
# ==================
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ==================
# Azure OpenAI
# ==================
AZURE_OPENAPI_KEY=your_azure_openai_key
AZURE_OPENAPI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAPI_DEPLOYMENT=GPT-4
AZURE_OPENAPI_VERSION=2024-06-01-preview

# ==================
# JSearch API (RapidAPI) - Job Ingestion
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# ==================
JSEARCH_API_KEY=your_rapidapi_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# ==================
# Notes
# ==================
# 1. For local dev: use localhost for REDIS_HOST and DATABASE_URL
# 2. For Docker Compose: change to 'postgres' and 'redis' respectively
# 3. NEVER commit actual keys to version control
# 4. Add .env to .gitignore
