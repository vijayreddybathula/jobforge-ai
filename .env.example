# JobForge AI - Environment Configuration Template
# Copy this to .env and fill in your values



# ==================
# Database Config (PostgreSQL)
# ==================
# PostgreSQL master password
POSTGRES_PASSWORD=jobforge_password

# Database URL (used by SQLAlchemy and Alembic)
# Format: postgresql://user:password@host:port/database
# For local development: postgresql://postgres:jobforge_password@localhost:5432/jobforge_ai
# For Docker: postgresql://postgres:jobforge_password@postgres:5432/jobforge_ai
DATABASE_URL=postgresql://postgres:jobforge_password@localhost:5432/jobforge_ai

# ==================
# Redis Config
# ==================
# Redis master password
REDIS_PASSWORD=redis_password

# Redis host and port
REDIS_HOST=localhost  # Use 'redis' when running in Docker
REDIS_PORT=6379

# Celery Broker URL (message queue for background jobs)
# Format: redis://:password@host:port/db_number
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/1

# Celery Result Backend (stores task results)
# Format: redis://:password@host:port/db_number
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/2

# ==================
# FastAPI Config
# ==================
# API host and port
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==================
# Optional: Job Ingestion Config
# ==================
# LinkedIn credentials (if using LinkedIn scraping)
# LINKEDIN_EMAIL=your-email@example.com
# LINKEDIN_PASSWORD=your-password

# ==================
# Optional: Resume Analyzer Config
# ==================
# Resume storage path
RESUME_STORAGE_PATH=./storage/resumes

# ==================
# Optional: Scoring Config
# ==================
# Score weighting file
SCORING_WEIGHTS_FILE=./config/scoring_weights.json

# ==================
# Optional: Email Config
# ==================
# SMTP settings for notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=your-email@gmail.com

# ==================
# Notes
# ==================
# 1. For local development (terminal): Use localhost for REDIS_HOST and DATABASE_URL
# 2. For Docker Compose: Change to 'postgres' and 'redis' respectively
# 3. Keep POSTGRES_PASSWORD and REDIS_PASSWORD consistent between .env and docker-compose.yml
# 4. NEVER commit actual API keys to version control
# 5. Add .env to .gitignore: echo ".env" >> .gitignore
